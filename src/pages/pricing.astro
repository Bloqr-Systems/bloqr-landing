---
export const prerender = true;
import '../styles/global.css';
import Nav from '../components/Nav.svelte';
import ClosedBetaBanner from '../components/ClosedBetaBanner.svelte';
import Footer from '../components/Footer.svelte';
import BaseHead from '../components/BaseHead.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import Pricing from '../components/Pricing.svelte';
import PricingTable from '../components/PricingTable.svelte';
import { SITE_URL, LINKS, PAGE_META } from '../config';

const meta = {
  title:       PAGE_META.pricing.title,
  description: PAGE_META.pricing.description,
  url:         `${SITE_URL}/pricing`,
  image:       `${SITE_URL}/og/pricing.png`,
};

const pricingSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "name": meta.title,
      "description": meta.description,
      "url": meta.url,
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",    "item": SITE_URL },
        { "@type": "ListItem", "position": 2, "name": "Pricing", "item": meta.url },
      ]
    },
    {
      "@type": "Offer",
      "name": "Starter (Personal)",
      "description": "Fully managed Web API/SaaS for households who just want it handled.",
      "price": "3.99",
      "priceCurrency": "USD",
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "price": "3.99",
        "priceCurrency": "USD",
        "unitText": "MONTH"
      },
      "url": meta.url
    },
    {
      "@type": "Offer",
      "name": "Dev Pro",
      "description": "SDK license, full pipeline, streaming API, and local library embedding with web API access.",
      "price": "24.99",
      "priceCurrency": "USD",
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "price": "24.99",
        "priceCurrency": "USD",
        "unitText": "MONTH"
      },
      "url": meta.url
    },
    {
      "@type": "Offer",
      "name": "Vendor",
      "description": "Multi-instance management, resource-based consumption, API marketplace listing.",
      "price": "29.99",
      "priceCurrency": "USD",
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "price": "29.99",
        "priceCurrency": "USD",
        "unitText": "MONTH"
      },
      "url": meta.url
    },
    {
      "@type": "Offer",
      "name": "Enterprise",
      "description": "Unlimited scale, custom SLA, dedicated infrastructure, white-label options.",
      "url": meta.url
    }
  ]
};
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title={meta.title}
    description={meta.description}
    canonicalURL={meta.url}
    ogImage={meta.image}
  />
  <SchemaOrg schema={pricingSchema} />
</head>
<body>
  <ClosedBetaBanner client:load />
  <Nav client:idle transition:persist="nav" />

  <main id="main-content">

    <!-- ── Page header ── -->
    <header class="page-header">
      <div class="container">
        <div class="header-label">Pricing</div>
        <h1>Transparent pricing.<br /><em>Value you can measure.</em></h1>
        <p class="header-sub">
          Every plan is built around real capabilities — managed compilation,
          AI-curated threat intelligence, DNS integrations, and developer tooling.
          When you go beyond your plan's limits, usage-based pricing charges only
          what you use, billed automatically via Stripe. Early access locks in your rate for life.
        </p>
        <div class="header-cta">
          <a href={LINKS.app} class="btn btn-primary" rel="noopener noreferrer" target="_blank">Get started →</a>
          <a href="#compare" class="btn btn-outline">Compare all plans</a>
        </div>
      </div>
    </header>

    <!-- ── Pricing tiers (reused component) ── -->
    <Pricing client:load />

    <!-- ── Licensing & access model ── -->
    <section class="access-section" id="access" aria-labelledby="access-heading">
      <div class="container">
        <div class="access-grid">
          <div class="access-content">
            <p class="section-label">Access Models</p>
            <h2 id="access-heading">Three ways to use Bloqr.<br />One billing model.</h2>
            <p>
              The core compiler library is commercial-grade software — purpose-built,
              actively maintained, and backed by a subscription that covers hosting,
              AI-curated threat intelligence updates, and ongoing development. That
              commitment requires a subscription rather than a free tier.
            </p>
            <p>
              Regardless of how you deploy — SaaS, local SDK, or CLI — any web API call you
              make is checked for entitlements at the API gateway and billed as usage above
              your plan's included limits. Your license tier determines which API modes and
              features are available.
            </p>
            <a href="/#waitlist" class="btn btn-outline">Join the waitlist</a>
          </div>

          <!-- Access model cards -->
          <div class="access-cards">
            <div class="access-card">
              <div class="access-icon" aria-hidden="true">☁️</div>
              <div class="access-body">
                <strong>Web API / SaaS</strong>
                <p>Fully managed, hosted by Bloqr. No local install required. All plans.</p>
              </div>
            </div>
            <div class="access-card">
              <div class="access-icon" aria-hidden="true">📦</div>
              <div class="access-body">
                <strong>Local SDK embedding</strong>
                <p>Embed the compiler locally via licensed SDKs (JSR / npm). Web API calls from the SDK are usage-billed and entitlement-checked. Dev Pro and above, and Vendor plans.</p>
              </div>
            </div>
            <div class="access-card">
              <div class="access-icon" aria-hidden="true">⚙️</div>
              <div class="access-body">
                <strong>CLI build tools</strong>
                <p>Use the compiler as part of local CI/CD pipelines and build processes. Available as a standalone add-on or included in Dev and developer plans.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Comparison table ── -->
    <div id="compare">
      <PricingTable />
    </div>

    <!-- ── API Marketplace section ── -->
    <section class="marketplace-section" aria-labelledby="marketplace-heading">
      <div class="container">
        <div class="section-header">
          <p class="section-label">API Networks</p>
          <h2 id="marketplace-heading" class="section-title">
            Find Bloqr on the API networks you already use.
          </h2>
          <p class="section-sub">
            On marketplace platforms that handle billing, your existing account covers
            Bloqr usage. Subscription entitlements are verified at every API call
            regardless of which platform you use.
          </p>
        </div>

        <div class="marketplace-grid">
          <div class="marketplace-card">
            <div class="marketplace-header">
              <span class="marketplace-name">RapidAPI</span>
              <span class="coming-soon-badge">Coming soon</span>
            </div>
            <p>
              Subscribe via RapidAPI. Their platform handles billing — your existing RapidAPI
              account covers Bloqr usage alongside any other APIs you use.
            </p>
          </div>

          <div class="marketplace-card">
            <div class="marketplace-header">
              <span class="marketplace-name">Postman API Network</span>
              <span class="coming-soon-badge">Coming soon</span>
            </div>
            <p>
              Discover and test Bloqr's API directly in Postman. Authenticate with your
              Bloqr subscription key — no separate account needed.
            </p>
          </div>

          <div class="marketplace-card">
            <div class="marketplace-header">
              <span class="marketplace-name">AWS Marketplace</span>
              <span class="coming-soon-badge">Coming soon</span>
            </div>
            <p>
              Subscribe and bill through AWS Marketplace for seamless enterprise procurement.
              Ideal for teams already using AWS infrastructure.
            </p>
          </div>

          <div class="marketplace-card">
            <div class="marketplace-header">
              <span class="marketplace-name">Azure API Management</span>
              <span class="coming-soon-badge">Coming soon</span>
            </div>
            <p>
              Integrate Bloqr into your Azure API Management pipeline for centralised
              governance, rate limiting, and audit logs.
            </p>
          </div>

          <div class="marketplace-card">
            <div class="marketplace-header">
              <span class="marketplace-name">JSR / npm</span>
              <span class="coming-soon-badge">Coming soon</span>
            </div>
            <p>
              SDK packages published to JSR and npm. Install the licensed SDK wrapper and
              authenticate with your subscription key to unlock the local embedding model.
            </p>
          </div>

          <div class="marketplace-card">
            <div class="marketplace-header">
              <span class="marketplace-name">Apilayer</span>
              <span class="coming-soon-badge">Coming soon</span>
            </div>
            <p>
              Discover and subscribe to Bloqr on Apilayer for quick integration into
              existing API pipelines with built-in usage monitoring.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Billing FAQ ── -->
    <section class="faq-section" aria-labelledby="faq-heading">
      <div class="container">
        <div class="section-header">
          <p class="section-label">Billing FAQ</p>
          <h2 id="faq-heading" class="section-title">Questions about billing.</h2>
        </div>

        <div class="faq-list">
          <details class="faq-item">
            <summary>Is there a free tier?</summary>
            <div class="faq-answer">
              Bloqr doesn't offer a free tier because what you get — fully managed
              filter compilation, AI-curated threat intelligence, DNS provider
              integrations, and ongoing updates — has real infrastructure and
              maintenance cost. Rather than offering a degraded free experience,
              every paid plan starts with a meaningful set of capabilities at
              $3.99/month (personal Starter). All paid plans include a 30-day
              money-back guarantee, no questions asked.
            </div>
          </details>

          <details class="faq-item">
            <summary>What counts as "usage" above my plan limit?</summary>
            <div class="faq-answer">
              Usage-based pricing lets you go beyond your plan's included limits
              without requiring a plan upgrade. Each compile call above your daily limit is
              billed at $0.20/compile. Rules above your per-compile limit are billed
              at $0.10/1,000 rules. Web API calls made from the local SDK are always
              billed as usage and require verified entitlements regardless of plan.
              You only pay for what you actually use — Stripe charges are calculated
              automatically at the end of each billing period.
            </div>
          </details>

          <details class="faq-item">
            <summary>Can I use web APIs with the local SDK?</summary>
            <div class="faq-answer">
              Yes. The local SDK can call Bloqr's web APIs, but every call is checked
              at the API gateway to verify you have the right entitlements for that API
              mode (REST, streaming, async, etc.) and is billed as usage. This applies
              to all plans — there is no free pass for locally-embedded SDK callers.
            </div>
          </details>

          <details class="faq-item">
            <summary>How does SDK licensing work?</summary>
            <div class="faq-answer">
              The SDK license is included in Dev Pro, Vendor, and Enterprise plans, and
              available as a $9.99/month add-on to other plans. Your subscription key
              unlocks the SDK at runtime — revoked or expired subscriptions immediately
              disable SDK functionality. The license is non-transferable and tied to
              your Bloqr account.
            </div>
          </details>

          <details class="faq-item">
            <summary>Can I switch plans mid-month?</summary>
            <div class="faq-answer">
              Yes — upgrades take effect immediately and are prorated. Downgrades take
              effect at the end of your current billing period. Usage charges from the
              current period are never refunded, but subscription fees are.
            </div>
          </details>

          <details class="faq-item">
            <summary>Is there a free trial for paid plans?</summary>
            <div class="faq-answer">
              All paid plans include a 30-day money-back guarantee, no questions asked.
              Cancel within 30 days and you'll receive a full refund on subscription
              fees. Usage charges are non-refundable.
            </div>
          </details>

          <details class="faq-item">
            <summary>What API modes are available and how are they priced?</summary>
            <div class="faq-answer">
              REST API ($2.99/mo add-on), Streaming API ($4.99/mo add-on), and
              Async/batch API ($3.99/mo add-on) are the three modes. Dev Pro and above
              include all three. Each mode can also be added individually to Starter or
              Dev plans. Usage above plan limits is billed per-call regardless of mode.
            </div>
          </details>

          <details class="faq-item">
            <summary>Can my company pay by invoice?</summary>
            <div class="faq-answer">
              Vendor and Enterprise plans support invoice billing and purchase order
              workflows. <a href="/#waitlist">Contact us</a> to discuss your requirements.
            </div>
          </details>

          <details class="faq-item">
            <summary>What license does Bloqr use for its libraries?</summary>
            <div class="faq-answer">
              The core compiler library is proprietary and commercial. SDK wrapper packages
              are distributed under a commercial license — you need an active Bloqr
              subscription to use them in production. The license is enforced at runtime
              via your subscription key. Source code for the SDK wrappers may be reviewed
              but not redistributed without a separate agreement.
            </div>
          </details>

          <details class="faq-item">
            <summary>Is Bloqr available on RapidAPI or other API marketplaces?</summary>
            <div class="faq-answer">
              Listings on RapidAPI, Postman API Network, AWS Marketplace, Azure API
              Management, and Apilayer are coming soon. When live, your existing
              marketplace account will cover Bloqr usage — entitlements are synced
              automatically.
            </div>
          </details>
        </div>
      </div>
    </section>

    <!-- ── Final CTA ── -->
    <section class="pricing-cta" aria-label="Get started with Bloqr">
      <div class="container">
        <h2>Internet Hygiene. Automated.</h2>
        <p>Pick a plan. Set it. Forget it.</p>
        <div class="cta-actions">
          <a href={LINKS.app} class="btn btn-primary" rel="noopener noreferrer" target="_blank">Get started →</a>
          <a href={LINKS.docs} class="btn btn-outline" rel="noopener noreferrer" target="_blank">
            Read the docs
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</body>
</html>

<style>
  /* ── Page header ── */
  .page-header {
    padding: 96px 0 72px;
    text-align: center;
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .page-header::before {
    content: '';
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%);
    width: 700px; height: 400px;
    background: radial-gradient(ellipse at center, rgba(255,85,0,0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .header-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 20px;
  }

  .page-header h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }

  .page-header h1 em {
    font-style: normal;
    background: linear-gradient(135deg, var(--orange) 0%, #FF8833 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .header-sub {
    font-size: 1.05rem;
    color: var(--text-2);
    max-width: 520px;
    margin: 0 auto 36px;
    line-height: 1.6;
  }

  .header-cta {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── Section labels (reusable within page) ── */
  .section-label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 12px;
  }

  .section-title {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 700;
    color: var(--text-1);
    line-height: 1.2;
    margin-bottom: 16px;
  }

  .section-sub {
    font-size: 0.97rem;
    color: var(--text-2);
    max-width: 580px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .section-header {
    text-align: center;
    margin-bottom: 48px;
  }

  /* ── Access model section ── */
  .access-section {
    padding: 80px 0;
    border-top: 1px solid var(--border);
  }

  .access-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  @media (max-width: 800px) {
    .access-grid { grid-template-columns: 1fr; gap: 40px; }
  }

  .access-content h2 {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }

  .access-content p {
    font-size: 0.97rem;
    color: var(--text-2);
    line-height: 1.75;
    margin-bottom: 16px;
  }

  .access-cards {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .access-card {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px 22px;
  }

  .access-icon {
    font-size: 1.5rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .access-body strong {
    display: block;
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--text-1);
    margin-bottom: 4px;
  }

  .access-body p {
    font-size: 0.875rem;
    color: var(--text-2);
    line-height: 1.6;
    margin: 0;
  }

  /* ── API Marketplace section ── */
  .marketplace-section {
    padding: 80px 0;
    border-top: 1px solid var(--border);
  }

  .marketplace-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  @media (max-width: 900px) {
    .marketplace-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .marketplace-grid { grid-template-columns: 1fr; }
  }

  .marketplace-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px 20px;
  }

  .marketplace-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }

  .marketplace-name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--text-1);
  }

  .coming-soon-badge {
    background: var(--bg-elevated);
    border: 1px solid var(--border-2);
    border-radius: 20px;
    padding: 2px 10px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-3);
    white-space: nowrap;
  }

  .marketplace-card p {
    font-size: 0.875rem;
    color: var(--text-2);
    line-height: 1.6;
    margin: 0;
  }

  /* ── Billing FAQ section ── */
  .faq-section {
    padding: 80px 0;
    border-top: 1px solid var(--border);
  }

  .faq-list {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .faq-item {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    transition: border-color 150ms;
  }

  .faq-item[open] {
    border-color: var(--border-2);
  }

  .faq-item summary {
    padding: 18px 22px;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-1);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .faq-item summary::-webkit-details-marker { display: none; }

  .faq-item summary::after {
    content: '+';
    color: var(--text-3);
    font-size: 1.1rem;
    font-weight: 400;
    flex-shrink: 0;
    transition: transform 200ms;
  }

  .faq-item[open] summary::after {
    transform: rotate(45deg);
  }

  .faq-answer {
    padding: 0 22px 18px;
    font-size: 0.9rem;
    color: var(--text-2);
    line-height: 1.7;
  }

  .faq-answer a {
    color: var(--orange);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ── Final CTA ── */
  .pricing-cta {
    padding: 96px 0;
    text-align: center;
    border-top: 1px solid var(--border);
  }

  .pricing-cta h2 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 12px;
  }

  .pricing-cta p {
    font-size: 1.1rem;
    color: var(--text-3);
    margin-bottom: 36px;
  }

  .cta-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
