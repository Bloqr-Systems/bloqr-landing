{
  "name": "bloqr-landing",
  "version": "0.1.0",
  "description": "Bloqr landing page — Astro + Svelte, deployed to Cloudflare Workers",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "icons": "node scripts/generate-icons.mjs",
    "prebuild": "node scripts/generate-icons.mjs",
    "build": "astro build",
    "preview": "wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "sync-blog": "npx tsx scripts/sync-blog-from-db.ts",
    "migrate-blog": "npx tsx scripts/migrate-blog-posts.ts",
    "migrate:auth": "tsx scripts/migrate-better-auth.ts",
    "migrate:email": "npx tsx scripts/migrate-email-schema.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "@astrojs/compiler-rs": "^0.1.10",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/svelte": "^8.1.2",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@neondatabase/serverless": "^1.1.0",
    "astro": "^6.4.8",
    "better-auth": "^1.6.22",
    "mermaid": "^11.16.0",
    "posthog-js": "^1.395.0",
    "posthog-node": "^5.38.6",
    "svelte": "^5.56.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/puppeteer": "^1.1.0",
    "@cloudflare/workers-types": "^4.20260629.1",
    "@types/node": "^22.20.0",
    "sharp": "^0.34.5",
    "tsx": "^4.22.4",
    "vitest": "^4.1.9",
    "wrangler": "^4.95.0"
  },
  "engines": {
    "node": "^20.20.0 || >=22.22.0"
  }
}
